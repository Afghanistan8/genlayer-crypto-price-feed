# GenLayer Secure API Proxy - Environment Variables
# =====================================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to GitHub - it contains secrets!

# Proxy Security Secret
# This is a password that your GenLayer contract must include
# when calling the proxy. Change this to something random.
PROXY_SECRET=your-secret-password-here

# OpenWeatherMap API Key
# Get free key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key-here

# NewsAPI Key
# Get free key at: https://newsapi.org
NEWS_API_KEY=your-newsapi-key-here

# Alpha Vantage API Key (Stock prices)
# Get free key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=your-alphavantage-key-here
